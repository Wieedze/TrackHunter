# TrackHunter — Environment Variables
# Copy this file to .env and fill in your values.

# Cloudflare Worker URL (proxy for Bandcamp, Beatport, Traxsource)
VITE_WORKER_URL=http://localhost:8787

# Spotify (Client ID only — no secret needed with PKCE)
VITE_SPOTIFY_CLIENT_ID=

# YouTube Data API v3
VITE_YOUTUBE_API_KEY=

# Discogs
VITE_DISCOGS_TOKEN=
